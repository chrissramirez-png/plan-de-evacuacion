# Gemini AI
GEMINI_API_KEY=tu-api-key-de-google-ai-studio

# Supabase — auto-configurados por el Hub al deployar
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Hub
NEXT_PUBLIC_HUB_URL=https://cf-innovation-hub.up.railway.app

# Metricas — auto-configurado por el Hub
METRICS_API_KEY=tu-metrics-api-key

# Dominio permitido para login (server-side)
ALLOWED_DOMAIN=comunidadfeliz.cl
# Dominio permitido para login (client-side, usado en callback/confirm)
NEXT_PUBLIC_ALLOWED_DOMAIN=comunidadfeliz.cl

# Slack Bot (solo si capabilities incluye slack_bot)
# SLACK_BOT_TOKEN=xoxb-tu-token
# SLACK_SIGNING_SECRET=tu-signing-secret

# Webhooks (solo si usas webhooks)
# WEBHOOK_SECRET=tu-webhook-secret
